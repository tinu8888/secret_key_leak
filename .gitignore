# ---- Large project artifacts (traces saved, but big binaries not committed) ----
# Captured trace archives and trained models are reproduced from manifests/cards, not stored in git.
traces/*.npz
models/*.pt

# Keep the directories themselves tracked.
!traces/.gitkeep
!models/.gitkeep

